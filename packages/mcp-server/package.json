{
  "name": "@ocf/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol (MCP) server for Open Career Format. Exposes career tools to AI clients and orchestrates browser application workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "zod": "^3.25.0",
    "@ocf/core": "workspace:*",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.0",
    "tsx": "^4.19.0"
  }
}
